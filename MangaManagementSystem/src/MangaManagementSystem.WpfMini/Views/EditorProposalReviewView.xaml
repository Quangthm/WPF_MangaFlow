<UserControl x:Class="MangaManagementSystem.WpfMini.Views.EditorProposalReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- LEFT: Queue Panel (Master)                          -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Proposal Review Queue" FontSize="18" FontWeight="Bold"
                       Foreground="#2c3e50"/>

            <!-- Status Filter + Refresh -->
            <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="8"
                    Margin="0,8,0,8" BorderBrush="#ddd" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="#666"
                               FontSize="12" Margin="0,0,8,0"/>
                    <ComboBox SelectedValue="{Binding StatusFilter}"
                              MinWidth="160" FontSize="13">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Under Editorial Review"/>
                        <ComboBoxItem Content="Under Board Review"/>
                        <ComboBoxItem Content="Revision Requested"/>
                    </ComboBox>
                    <Button Content="⟳" Command="{Binding LoadQueueCommand}"
                            Background="#3498db" Foreground="White"
                            BorderThickness="0" Padding="8,4" Margin="8,0,0,0"
                            FontSize="16" ToolTip="Refresh"/>
                </StackPanel>
            </Border>

            <!-- Loading indicator -->
            <TextBlock Grid.Row="2" Text="Loading queue..."
                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#999"
                       Visibility="{Binding IsQueueLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Error message -->
            <TextBlock Grid.Row="2" Text="{Binding QueueErrorMessage}" Foreground="#e74c3c"
                       TextWrapping="Wrap" VerticalAlignment="Center"
                       Visibility="{Binding QueueErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Queue List -->
            <ListBox Grid.Row="2" ItemsSource="{Binding ProposalQueue}"
                     SelectedItem="{Binding SelectedProposal}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Background="Transparent" BorderThickness="0"
                     Visibility="{Binding IsQueueLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="0"
                                            BorderThickness="0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#d5e8f7"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#3498db"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#ebf5fb"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="6" Padding="12"
                                BorderBrush="#eee" BorderThickness="1">
                            <StackPanel>
                                <!-- Status Badge -->
                                <Border Background="{Binding StatusCode, Converter={StaticResource StatusToBrushConverter}}"
                                        CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding StatusDisplay}" Foreground="White"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>

                                <!-- Series Title + Version -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SeriesTitle}" FontWeight="Bold"
                                               FontSize="14" Foreground="#2c3e50"/>
                                    <TextBlock Text="{Binding ProposalVersionNo, StringFormat=' v{0}'}"
                                               FontSize="12" Foreground="#7f8c8d" VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>

                                <!-- Submitter -->
                                <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                                    <Run Text="by "/>
                                    <Run Text="{Binding SubmitterDisplayName}" FontWeight="SemiBold"/>
                                </TextBlock>

                                <!-- Date + File -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SubmittedAtDisplay}" FontSize="11"
                                               Foreground="#95a5a6"/>
                                    <TextBlock Text="{Binding ProposalFileName, StringFormat=' · {0}'}"
                                               FontSize="11" Foreground="#95a5a6" Margin="4,0,0,0"/>
                                </StackPanel>

                                <!-- Comments preview (if revision requested) -->
                                <TextBlock Text="{Binding Comments}" FontSize="11" Foreground="#e67e22"
                                           TextTrimming="CharacterEllipsis" MaxHeight="20"
                                           Margin="0,4,0,0" FontStyle="Italic"
                                           Visibility="{Binding Comments, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <TextBlock Grid.Row="2" Text="No proposals in queue"
                       Foreground="#95a5a6" FontSize="14" FontStyle="Italic"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}"/>
            <ListBox Grid.Row="2" ItemsSource="{Binding ProposalQueue}"
                SelectedItem="{Binding SelectedProposal}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                Background="Transparent" BorderThickness="0"
                     >
                <ListBox.Resources>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="0"
                                        BorderThickness="0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#d5e8f7"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#3498db"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#ebf5fb"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>

                <ListBox.Visibility>
                    <Binding ConverterParameter="false" Converter="{StaticResource BoolToVisibilityConverter}" Path="IsQueueLoading"/>
                </ListBox.Visibility>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="6" Padding="12"
                            BorderBrush="#eee" BorderThickness="1">
                            <StackPanel>
                                <!-- Status Badge -->
                                <Border Background="{Binding StatusCode, Converter={StaticResource StatusToBrushConverter}}"
                                    CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding StatusDisplay}" Foreground="White"
                                        FontSize="10" FontWeight="Bold"/>
                                </Border>

                                <!-- Series Title + Version -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SeriesTitle}" FontWeight="Bold"
                                        FontSize="14" Foreground="#2c3e50"/>
                                    <TextBlock Text="{Binding ProposalVersionNo, StringFormat=' v\{0\}'}"
                                        FontSize="12" Foreground="#7f8c8d" VerticalAlignment="Center"
                                        Margin="4,0,0,0"/>
                                </StackPanel>

                                <!-- Submitter -->
                                <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0"><Run Text="by "/><Run Text=" "/><Run Text="{Binding SubmitterDisplayName}" FontWeight="SemiBold"/></TextBlock>

                                <!-- Date + File -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SubmittedAtDisplay}" FontSize="11"
                                        Foreground="#95a5a6"/>
                                    <TextBlock Text="{Binding ProposalFileName, StringFormat=' · \{0\}'}"
                                        FontSize="11" Foreground="#95a5a6" Margin="4,0,0,0"/>
                                </StackPanel>

                                <!-- Comments preview (if revision requested) -->
                                <TextBlock Text="{Binding Comments}" FontSize="11" Foreground="#e67e22"
                                    TextTrimming="CharacterEllipsis" MaxHeight="20"
                                    Margin="0,4,0,0" FontStyle="Italic"
                                    Visibility="{Binding Comments, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ═══ Divider ═══ -->
        <Rectangle Grid.Column="1" Width="1" Fill="#ddd" Margin="0,10"/>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- RIGHT: Detail + Actions Panel (Detail)              -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2" Margin="10">
            <!-- Empty state when no selection -->
            <TextBlock Text="Select a proposal from the queue to review"
                       Foreground="#95a5a6" FontSize="16" FontStyle="Italic"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}"/>

            <!-- Loading -->
            <TextBlock Text="Loading detail..." HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#999"
                       Visibility="{Binding IsDetailLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Detail Content -->
            <ScrollViewer Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Margin="0,0,12,12">

                    <!-- ═══ Series Info Card ═══ -->
                    <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedDetail.SeriesTitle}" FontSize="22"
                                           FontWeight="Bold" Foreground="#2c3e50"/>
                                <Border Background="{Binding SelectedDetail.ProposalStatusCode, Converter={StaticResource StatusToBrushConverter}}"
                                        CornerRadius="4" Padding="8,3" Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedDetail.StatusDisplay}" Foreground="White"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedDetail.SeriesSlug, StringFormat='/{0}'}"
                                       Foreground="#7f8c8d" FontSize="13" Margin="0,2,0,0"/>

                            <!-- Genres as pills -->
                            <WrapPanel Margin="0,8,0,0">
                                <ItemsControl ItemsSource="{Binding SelectedDetail.Genres}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#e8f4fd" CornerRadius="12" Padding="10,3"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="{Binding GenreName}" FontSize="12"
                                                           Foreground="#2980b9"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>

                            <!-- Tags as pills -->
                            <WrapPanel Margin="0,4,0,0">
                                <ItemsControl ItemsSource="{Binding SelectedDetail.Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#f0f0f0" CornerRadius="12" Padding="10,3"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="{Binding TagName}" FontSize="11" Foreground="#666"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Proposal Info Card ═══ -->
                    <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDetail.ProposalTitle, StringFormat='Proposal: {0}'}"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#2c3e50"/>

                            <TextBlock Text="{Binding SelectedDetail.ProposalVersionNo, StringFormat='Version {0}'}"
                                       FontSize="13" Foreground="#7f8c8d" Margin="0,2,0,0"/>

                            <!-- Synopsis -->
                            <TextBlock Text="Synopsis" FontSize="12" FontWeight="Bold"
                                       Foreground="#555" Margin="0,10,0,4"/>
                            <Border Background="#f9f9f9" CornerRadius="6" Padding="12">
                                <TextBlock Text="{Binding SelectedDetail.SynopsisSnapshot}"
                                           TextWrapping="Wrap" FontSize="13" Foreground="#444"
                                           MaxHeight="120"/>
                            </Border>

                            <!-- Metadata Grid -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Submitted by:" FontSize="12" Foreground="#888"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDetail.SubmitterDisplayName}"
                                           FontSize="12" Foreground="#333" Margin="4,0,20,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Date:" FontSize="12" Foreground="#888"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedDetail.SubmittedAtDisplay}"
                                           FontSize="12" Foreground="#333" Margin="4,0,0,0"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Proposal file:" FontSize="12" Foreground="#888" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDetail.ProposalFileName}"
                                           FontSize="12" Foreground="#2980b9" Margin="4,6,0,0"
                                           TextDecorations="Underline" Cursor="Hand"/>
                            </Grid>

                            <!-- Previous reviewer comments (when revision requested) -->
                            <Border Background="#fff8e1" CornerRadius="6" Padding="12" Margin="0,10,0,0"
                                    BorderBrush="#ffe082" BorderThickness="1"
                                    Visibility="{Binding SelectedDetail.Comments, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Previous Review Comments" FontSize="11" FontWeight="Bold"
                                               Foreground="#e67e22"/>
                                    <TextBlock Text="{Binding SelectedDetail.Comments}" TextWrapping="Wrap"
                                               FontSize="12" Foreground="#856404" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Action Mode Selector ═══ -->
                    <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Editor Action" FontSize="14" FontWeight="Bold"
                                       Foreground="#2c3e50" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="✓ Request Revision"
                                             IsChecked="{Binding IsRevisionMode}"
                                             Command="{Binding SetRevisionModeCommand}"
                                             Margin="0,0,12,0" FontSize="13" Cursor="Hand"
                                             IsEnabled="{Binding SelectedDetail.CanRequestRevision}"/>
                                <RadioButton Content="→ Pass to Board"
                                             IsChecked="{Binding IsPassToBoardMode}"
                                             Command="{Binding SetPassToBoardModeCommand}"
                                             Margin="0,0,12,0" FontSize="13" Cursor="Hand"
                                             IsEnabled="{Binding SelectedDetail.CanPassToBoard}"/>
                                <RadioButton Content="✕ Cancel Series"
                                             IsChecked="{Binding IsCancelMode}"
                                             Command="{Binding SetCancelModeCommand}"
                                             FontSize="13" Cursor="Hand"
                                             IsEnabled="{Binding SelectedDetail.CanCancel}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Action Form ═══ -->
                    <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <!-- Comments -->
                            <TextBlock Text="Comments" FontSize="12" FontWeight="Bold" Foreground="#555"/>
                            <TextBox Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80" Padding="8" Margin="0,4,0,10"
                                     FontSize="13"/>

                            <!-- Markup File -->
                            <TextBlock Text="Markup File" FontSize="12" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="(required for Cancel, optional for Revision / Pass to Board)"
                                       FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MarkupFileName}"
                                         IsReadOnly="True" Padding="8"
                                         Foreground="#666" FontSize="13"/>
                                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseMarkupFileCommand}"
                                        Background="#3498db" Foreground="White"
                                        BorderThickness="0" Padding="10,6" Margin="6,0"/>
                                <Button Grid.Column="2" Content="Clear" Command="{Binding ClearMarkupFileCommand}"
                                        Background="#95a5a6" Foreground="White"
                                        BorderThickness="0" Padding="10,6"/>
                            </Grid>

                            <!-- Action Messages -->
                            <TextBlock Text="{Binding ActionErrorMessage}" Foreground="#e74c3c"
                                       TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12"
                                       Visibility="{Binding ActionErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding ActionSuccessMessage}" Foreground="#27ae60"
                                       TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12"
                                       Visibility="{Binding ActionSuccessMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Action buttons based on selected mode -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="✓ Request Revision"
                                        Command="{Binding SubmitRevisionCommand}"
                                        Background="#e67e22" Foreground="White"
                                        BorderThickness="0" Padding="14,8" Margin="0,0,8,0"
                                        Visibility="{Binding IsRevisionMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                        IsEnabled="{Binding IsSubmittingAction, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}"/>
                                <Button Content="→ Pass to Board"
                                        Command="{Binding SubmitPassToBoardCommand}"
                                        Background="#2980b9" Foreground="White"
                                        BorderThickness="0" Padding="14,8" Margin="0,0,8,0"
                                        Visibility="{Binding IsPassToBoardMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                        IsEnabled="{Binding IsSubmittingAction, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}"/>
                                <Button Content="✕ Cancel Series"
                                        Command="{Binding SubmitCancelCommand}"
                                        Background="#e74c3c" Foreground="White"
                                        BorderThickness="0" Padding="14,8" Margin="0,0,8,0"
                                        Visibility="{Binding IsCancelMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                        IsEnabled="{Binding IsSubmittingAction, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}"/>
                            </StackPanel>

                            <!-- Processing indicator -->
                            <TextBlock Text="Processing..." Foreground="#3498db"
                                       FontStyle="Italic" FontSize="12" Margin="0,8,0,0"
                                       Visibility="{Binding IsSubmittingAction, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
