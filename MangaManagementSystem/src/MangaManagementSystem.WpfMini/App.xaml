<Application x:Class="MangaManagementSystem.WpfMini.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MangaManagementSystem.WpfMini.Converters"
             xmlns:vm="clr-namespace:MangaManagementSystem.WpfMini.ViewModels"
             xmlns:views="clr-namespace:MangaManagementSystem.WpfMini.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel → View DataTemplates -->
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ShellViewModel}">
                <views:ShellView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EditorProposalReviewViewModel}">
                <views:EditorProposalReviewView/>
            </DataTemplate>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
